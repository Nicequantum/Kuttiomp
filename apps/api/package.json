{
  "name": "@kuttiomp/api",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop kuttiomp-api",
    "pm2:restart": "pm2 restart kuttiomp-api",
    "pm2:logs": "pm2 logs kuttiomp-api",
    "pm2:status": "pm2 status",
    "pm2:setup": "powershell -ExecutionPolicy Bypass -File scripts/pm2-setup.ps1",
    "lint": "echo \"Python lint: install ruff for local linting\"",
    "build": "echo \"API build complete\""
  }
}