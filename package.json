{
  "name": "kuttiomp",
  "version": "0.4.0",
  "private": true,
  "description": "Kuttiomp — Narragansett Language Revitalization Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:migrate": "echo 'Apply supabase/migrations/001 through 004 in order via Supabase SQL Editor — see supabase/migrations/README.md'",
    "setup": "bash setup.sh"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  }
}