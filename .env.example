# =============================================================================
# Kuttiomp Environment Configuration (v0.4)
# Narragansett Language Revitalization Platform
#
# SETUP:
#   1. Copy this file to: .env (root), apps/api/.env, apps/admin/.env
#   2. Fill in credentials from Supabase, Clerk, and xAI dashboards
#   3. Never commit filled .env files (GitHub push protection blocks secrets)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (Database + Storage)
# Dashboard: https://supabase.com/dashboard
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# CLERK (Authentication)
# Dashboard: https://dashboard.clerk.com
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─────────────────────────────────────────────────────────────────────────────
# GROK / xAI (Linguistic Learning Assistance)
# Dashboard: https://console.x.ai → API Keys
# Required for: apps/api (GrokService, /api/grok/test, /api/v1/grok/*)
# Test after setup: GET http://localhost:8000/api/grok/test
# ─────────────────────────────────────────────────────────────────────────────
GROK_API_KEY=xai-your-key
GROK_API_BASE_URL=https://api.x.ai/v1

# ─────────────────────────────────────────────────────────────────────────────
# FASTAPI BACKEND
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# AUDIO STORAGE (Supabase Storage Bucket)
# Create bucket 'kuttiomp-audio' in Supabase Storage dashboard
# ─────────────────────────────────────────────────────────────────────────────
AUDIO_STORAGE_BUCKET=kuttiomp-audio
AUDIO_MAX_DURATION_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# CULTURAL GOVERNANCE
# ─────────────────────────────────────────────────────────────────────────────
SACRED_CONTENT_REQUIRES_ELDER_APPROVAL=true
DEFAULT_CONTENT_VISIBILITY=clan
PROTOCOL_VERSION=2.1