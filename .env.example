# =============================================================================
# Kuttiomp Environment Configuration
# Narragansett Language Revitalization Platform
#
# Copy this file to .env and fill in your credentials.
# Also copy to apps/api/.env and apps/admin/.env
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://tumwmmnvadrqfbkktcgc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://tumwmmnvadrqfbkktcgc.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Grok API (xAI) ---
GROK_API_KEY=your-grok-api-key
GROK_API_BASE_URL=https://api.x.ai/v1

# --- FastAPI Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Audio Storage ---
AUDIO_STORAGE_BUCKET=kuttiomp-audio
AUDIO_MAX_DURATION_SECONDS=300

# --- Cultural Access Control ---
SACRED_CONTENT_REQUIRES_ELDER_APPROVAL=true
DEFAULT_CONTENT_VISIBILITY=clan